# DevSync local/production environment placeholders.
# Copy to .env and fill in values. Never commit real secrets.

# PostgreSQL (required for backend)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=devsync
DATABASE_URL=
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Redis
# Provider-managed Redis (Render/Railway/Heroku) can supply a single REDIS_URL
# (redis://default:password@host:port or rediss://... for TLS); it is parsed
# by RedisUrlEnvironmentPostProcessor. Otherwise set the discrete values below.
REDIS_URL=
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
SPRING_REDIS_SSL_ENABLED=false
SPRING_REDIS_PASSWORD=

# Auth / JWT (JWT_SECRET must be at least 32 characters)
JWT_SECRET=
JWT_ACCESS_TOKEN_MINUTES=15
JWT_GUEST_TOKEN_MINUTES=120
REFRESH_TOKEN_DAYS=14
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax
REFRESH_COOKIE_NAME=refresh_token

# Frontend / CORS (comma-separated origins, no wildcards with credentials)
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
VITE_NODE_PREVIEW_ENABLED=false

# GitHub OAuth (optional)
GITHUB_OAUTH_ENABLED=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Document persistence
DOCUMENT_SNAPSHOT_DEBOUNCE_MS=3000
DOCUMENT_MAX_CONTENT_CHARS=500000

# Repository import limits
IMPORT_MAX_FILE_BYTES=26214400
IMPORT_COLLABORATION_MAX_BYTES=1048576
IMPORT_MAX_TOTAL_BYTES=104857600
IMPORT_MAX_FILES=2000

# Actuator
MANAGEMENT_HEALTH_REDIS_ENABLED=true
